generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int           @id @default(autoincrement())
  email             String        @unique
  name              String?
  password          String?
  image             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  accounts          Account[]
  role              Role          @default(USER)
  isApproved        Boolean       @default(false)
  canReportIssues   Boolean       @default(true)
  posts             Post[]
  chatSessions      ChatSession[]
  assignedChats     ChatSession[] @relation("AdminChats")
  issues            Issue[]
  communityPosts    CommunityPost[]
  comments          Comment[]
  products          Product[]     @relation("UserProducts")
  issueComments     IssueComment[] @relation("IssueComments")
  issueActivities   IssueActivity[]
  notifications     Notification[]
}

enum Role {
  USER
  ADMIN
  OWNER
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Post {
  id                 Int      @id @default(autoincrement())
  title              String
  slug               String   @unique
  content            String
  excerpt            String
  image              String?
  title_th           String?
  content_th         String?
  excerpt_th         String?
  published          Boolean  @default(false)
  authorId           Int
  author             User     @relation(fields: [authorId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  metaTitle_th       String?
  metaDescription_th String?
  metaKeywords_th    String?
}

model DemoRequest {
  id          String   @id @default(uuid())
  workEmail   String
  firstName   String
  lastName    String
  phoneNumber String
  companyName String
  country     String
  interest    String
  status      String   @default("PENDING") // PENDING, CONTACTED, CLOSED
  createdAt   DateTime @default(now())
}

// Chat Models
model ChatSession {
  id                  String    @id @default(cuid())
  userId              Int? // Optional: for logged-in users
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestId             String? // For anonymous users
  startedAt           DateTime  @default(now())
  endedAt             DateTime?
  messages            Message[]
  metadata            Json? // Store user preferences, context
  requestHumanSupport Boolean   @default(false) // User requested human help
  assignedAdminId     Int? // Admin handling this chat
  assignedAdmin       User?     @relation("AdminChats", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  lastMessageAt       DateTime? // For sorting by activity
  isActive            Boolean   @default(true) // Active or archived
  adminTookOver       Boolean   @default(false) // Admin took over conversation
  lastAdminReplyAt    DateTime? // Last time admin replied

  @@index([userId])
  @@index([guestId])
  @@index([startedAt])
  @@index([requestHumanSupport])
  @@index([assignedAdminId])
  @@index([lastMessageAt])
}

model Message {
  id            String        @id @default(cuid())
  sessionId     String
  session       ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          String // 'user' or 'assistant'
  content       String        @db.Text
  timestamp     DateTime      @default(now())
  metadata      Json? // Store tokens, model used, etc.
  feedback      ChatFeedback?
  isReadByAdmin Boolean       @default(false) // Track if admin read user messages
  isReadByUser  Boolean       @default(false) // Track if user read admin messages
  sentByAdmin   Boolean       @default(false) // Distinguish admin replies

  @@index([sessionId])
  @@index([timestamp])
  @@index([isReadByAdmin])
}

model ChatFeedback {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  rating    Int // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())

  @@index([rating])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  image       String?
  documents   Document[]
  categories  DocCategory[]
  owners      User[]        @relation("UserProducts")
  issues      Issue[]
  notifications Notification[]
  lineUsers   LineUser[]    @relation("ProductLineUsers")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model LineUser {
  id          String    @id @default(cuid())
  lineUserId  String    @unique
  displayName String?
  pictureUrl  String?
  products    Product[] @relation("ProductLineUsers")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DocCategory {
  id            String           @id @default(cuid())
  name          String
  order         Int              @default(0)
  productId     String
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  subcategories DocSubcategory[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([productId])
}

model DocSubcategory {
  id          String      @id @default(cuid())
  name        String
  order       Int         @default(0)
  categoryId  String
  category    DocCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  documents   Document[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
}

model Document {
  id            String          @id @default(cuid())
  title         String
  content       String          @db.Text
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  subcategoryId String?
  subcategory   DocSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  category      String?
  videoUrl      String?
  order         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  @@index([productId])
  @@index([subcategoryId])
}

model Issue {
  id            String   @id @default(cuid())
  ticketNumber  Int      @unique @default(autoincrement()) // Human-readable running number, displayed as ISS-0001
  title         String
  description   String   @db.Text
  status        String   @default("OPEN") // User side: OPEN, PENDING_REVIEW, CLOSED, REJECTED
  supportStatus String   @default("TODO") // Support side: TODO, IN_PROGRESS, COMPLETE, COMPLETED, REJECTED
  priority      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate       DateTime? // Target completion date, set by support
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  images        IssueImage[]
  comments      IssueComment[]
  activities    IssueActivity[]
  notifications Notification[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([productId])
}

model IssueImage {
  id        String   @id @default(cuid())
  url       String
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([issueId])
}

model IssueComment {
  id        String              @id @default(cuid())
  content   String              @db.Text
  type      String              // REJECTION, RESUBMIT
  issueId   String
  issue     Issue               @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    Int
  user      User                @relation("IssueComments", fields: [userId], references: [id])
  images    IssueCommentImage[]
  createdAt DateTime            @default(now())

  @@index([issueId])
  @@index([userId])
}

model IssueCommentImage {
  id        String       @id @default(cuid())
  url       String
  commentId String
  comment   IssueComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([commentId])
}

model CommunityPost {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Comment {
  id        String        @id @default(cuid())
  content   String        @db.Text
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())

  @@index([postId])
  @@index([userId])
}

model IssueActivity {
  id               String   @id @default(cuid())
  issueId          String
  issue            Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId           Int?
  user             User?    @relation(fields: [userId], references: [id])
  actorName        String?  // Fallback for system or deleted users
  type             String   // CREATED, STATUS_CHANGE, COMMENTED, etc.
  description      String   @db.Text
  createdAt        DateTime @default(now())

  @@index([issueId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  issueId   String?
  issue     Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  type      String   // ISSUE_CREATED, ISSUE_ACTIVITY
  title     String
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@index([isRead])
}
