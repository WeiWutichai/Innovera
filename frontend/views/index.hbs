<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>NovaOps — Built for modern product teams</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <meta name="description" content="NovaOps helps product teams plan, ship, and measure with clarity and speed.">
    <meta name="disabled-font-classes"
        content="font-roboto,font-montserrat,font-poppins,font-merriweather,font-work-sans,font-pt-serif,font-space-mono,font-manrope,font-playfair,font-instrument-serif,font-bricolage,font-newsreader,font-dm-sans,font-oswald,font-space-grotesk,font-geist-mono,font-quicksand,font-google-sans-flex,font-jakarta,font-geist">
    <link id="all-fonts-link-font-nunito" rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800&amp;display=swap">
    <style id="all-fonts-style-font-nunito">
        .font-nunito {
            font-family: 'Nunito', sans-serif !important;
        }
    </style>
</head>

<body class="antialiased selection:bg-white/10 selection:text-white text-white bg-neutral-950"
    style="font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto">
    <!-- Top Navigation -->
    <header class="sticky top-0 z-30 backdrop-blur-md bg-stone-950/70 border-b border-white/10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="#" class="inline-flex items-center gap-2">

                    <span class="text-sm sm:text-base font-medium tracking-tight font-nunito">NovaOps</span>
                </a>

                <!-- Nav -->
                <nav class="hidden md:flex items-center gap-6 text-sm text-white/70">
                    <a href="#features" class="hover:text-white transition-colors font-nunito">Features</a>
                    <a href="#cards" class="hover:text-white transition-colors font-nunito">Workflows</a>
                    <a href="#insights" class="hover:text-white transition-colors font-nunito">Insights</a>
                    <a href="#customers" class="hover:text-white transition-colors font-nunito">Customers</a>
                </nav>

                <!-- Actions -->
                <div class="flex items-center gap-2">
                    <a href="#"
                        class="hidden sm:inline-flex items-center h-9 px-3 rounded-lg border border-white/10 text-sm text-white/80 hover:text-white hover:border-white/20 transition-colors font-nunito">
                        Sign in
                    </a>
                    <a href="#"
                        class="inline-flex items-center h-9 px-3 rounded-lg bg-white text-stone-900 text-sm font-medium hover:bg-white/90 transition-colors font-nunito">
                        Start free
                        <svg width="18" height="18" viewBox="0 0 24 24" class="ml-1" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M5 12h14"></path>
                            <path d="M12 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Hero -->
    <section
        class="relative overflow-hidden bg-[url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/af0a80bd-7501-40ee-990b-69ed1cfcde25_3840w.jpg)] bg-cover">
        <div
            class="absolute -top-32 -left-32 w-[480px] h-[480px] bg-pink-500/10 blur-3xl rounded-full pointer-events-none">
        </div>
        <div
            class="absolute -bottom-48 -right-40 w-[520px] h-[520px] bg-pink-500/10 blur-3xl rounded-full pointer-events-none">
        </div>

        <div class="max-w-7xl md:py-24 grid grid-cols-1 lg:grid-cols-12 gap-10 mr-auto ml-auto pt-16 pr-6 pb-16 pl-6">
            <div class="lg:col-span-6 flex flex-col justify-center">
                <div
                    class="inline-flex gap-2 w-max text-xs text-white/80 bg-white/5 border-white/10 border rounded-full mb-4 pt-1 pr-2.5 pb-1 pl-2.5 backdrop-blur-lg items-center font-nunito">
                    <span class="inline-flex h-1.5 w-1.5 rounded-full bg-red-400"></span>
                    Ship faster with fewer meetings
                </div>
                <h1
                    class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl tracking-tight leading-tight font-nunito font-semibold">
                    Built for modern<br class="hidden md:block"> product teams
                </h1>
                <p class="mt-4 text-base sm:text-lg text-white/70 leading-relaxed font-nunito">
                    NovaOps is shaped by the habits of elite builders: tight feedback loops, ruthless prioritization,
                    and a commitment to craft.
                    Plan roadmaps, track sprints, and ship with confidence—without the overhead.
                </p>

                <div class="mt-6 flex flex-col sm:flex-row gap-3">
                    <a href="#"
                        class="inline-flex items-center justify-center h-11 hover:bg-white/90 transition text-sm font-medium text-stone-900 bg-white rounded-xl pr-4 pl-4 shadow-[0_2.8px_2.2px_rgba(0,_0,_0,_0.034),_0_6.7px_5.3px_rgba(0,_0,_0,_0.048),_0_12.5px_10px_rgba(0,_0,_0,_0.06),_0_22.3px_17.9px_rgba(0,_0,_0,_0.072),_0_41.8px_33.4px_rgba(0,_0,_0,_0.086),_0_100px_80px_rgba(0,_0,_0,_0.12)] font-nunito">
                        Create workspace
                        <svg width="18" height="18" viewBox="0 0 24 24" class="ml-1.5" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </a>
                    <a href="#"
                        class="inline-flex items-center justify-center h-11 hover:text-white hover:border-white/20 transition text-sm text-white/90 border-white/10 border rounded-xl pr-4 pl-4 shadow-[0px_0px_0px_1px_rgba(0,0,0,0.06),0px_1px_1px_-0.5px_rgba(0,0,0,0.06),0px_3px_3px_-1.5px_rgba(0,0,0,0.06),_0px_6px_6px_-3px_rgba(0,0,0,0.06),0px_12px_12px_-6px_rgba(0,0,0,0.06),0px_24px_24px_-12px_rgba(0,0,0,0.06)] backdrop-blur-lg font-nunito">
                        Book a demo
                        <svg width="18" height="18" viewBox="0 0 24 24" class="ml-1.5" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 6v6l4 2"></path>
                        </svg>
                    </a>
                </div>

                <div class="mt-6 flex items-center gap-4 text-xs text-white/60">
                    <!-- Dynamic User List Integration (Optional: To show we can use Handlebars) -->
                    {{#if users.length}}
                    <div class="flex -space-x-2">
                        {{#each users}}
                        <!-- Display up to 3 users for the hero section -->
                        <div class="h-6 w-6 rounded-full ring-2 ring-stone-950 bg-gray-500 flex items-center justify-center text-white text-[8px] overflow-hidden"
                            title="{{this.name}}">
                            {{this.name}}
                        </div>
                        {{/each}}
                        <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/bcaefeee-31cd-4c69-9a33-39ee0ad78c30_320w.jpg"
                            alt="Customer avatar" class="h-6 w-6 rounded-full ring-2 ring-stone-950 object-cover"
                            style="">
                    </div>
                    <span class="font-nunito">Trusted by {{users.length}} active users & 2,400+ teams</span>
                    {{else}}
                    <div class="flex -space-x-2">
                        <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/bcaefeee-31cd-4c69-9a33-39ee0ad78c30_320w.jpg"
                            alt="Customer avatar" class="h-6 w-6 rounded-full ring-2 ring-stone-950 object-cover"
                            style="">
                        <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/9c3af2bd-32da-4659-8095-1deb5455b9f6_800w.jpg"
                            alt="Customer avatar" class="h-6 w-6 rounded-full ring-2 ring-stone-950 object-cover"
                            style="">
                        <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/4d72eb51-d86e-431b-ad62-97cdf574a592_320w.jpg"
                            alt="Customer avatar" class="h-6 w-6 rounded-full ring-2 ring-stone-950 object-cover"
                            style="">
                    </div>
                    <span class="font-nunito">Trusted by 2,400+ teams • 4.9/5 satisfaction</span>
                    {{/if}}
                </div>
            </div>

            <!-- Hero visual -->
            <div class="lg:col-span-6">
                <div
                    class="relative sm:p-6 shadow-[0_2.8px_2.2px_rgba(0,_0,_0,_0.034),_0_6.7px_5.3px_rgba(0,_0,_0,_0.048),_0_12.5px_10px_rgba(0,_0,_0,_0.06),_0_22.3px_17.9px_rgba(0,_0,_0,_0.072),_0_41.8px_33.4px_rgba(0,_0,_0,_0.086),_0_100px_80px_rgba(0,_0,_0,_0.12)] bg-gradient-to-b from-white/[0.03] to-transparent border-white/10 border rounded-3xl pt-4 pr-4 pb-4 pl-4 backdrop-blur-lg">
                    <div class="grid grid-cols-12 gap-3">
                        <!-- Left tall card -->
                        <div class="col-span-12 md:col-span-6 space-y-3">
                            <div
                                class="group relative h-48 sm:h-56 rounded-2xl overflow-hidden border border-white/10 bg-stone-900">
                                <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/8d57793a-634a-4c7d-9968-fced612582e1_800w.jpg"
                                    alt="Product board" class="absolute inset-0 w-full h-full object-cover opacity-60"
                                    style="">
                                <div
                                    class="absolute inset-0 bg-gradient-to-t from-stone-950/70 via-stone-950/20 to-transparent">
                                </div>
                                <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between">
                                    <div>
                                        <p class="text-xs text-white/60 font-nunito">Sprint overview</p>
                                        <p class="text-lg font-semibold tracking-tight font-nunito">Velocity up 18%</p>
                                    </div>
                                    <span
                                        class="inline-flex items-center h-8 px-2 rounded-lg bg-white/5 border border-white/10 text-xs text-white/80 font-nunito">
                                        <svg width="18" height="18" viewBox="0 0 24 24" class="mr-1" fill="none"
                                            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                            stroke-linejoin="round" aria-hidden="true">
                                            <path d="M3 3v18h18"></path>
                                            <path d="M19 9l-6 6-4-4-4 4"></path>
                                        </svg>
                                        Trend
                                    </span>
                                </div>
                            </div>

                            <div
                                class="relative h-28 rounded-2xl overflow-hidden border border-white/10 bg-white/[0.02]">
                                <div class="absolute inset-0 flex items-center justify-between px-4">
                                    <div class="flex items-center gap-2">
                                        <span
                                            class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white/5 border border-white/10">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                                stroke-linejoin="round" aria-hidden="true" class="">
                                                <path d="M3 7h18"></path>
                                                <path d="M6 4h12v16H6z"></path>
                                                <path d="M8 11h8"></path>
                                                <path d="M8 15h5"></path>
                                            </svg>
                                        </span>
                                        <div class="">
                                            <p class="text-sm font-medium tracking-tight font-nunito">Backlog grooming
                                            </p>
                                            <p class="text-xs text-white/60 font-nunito">Reduce carryover by 32%</p>
                                        </div>
                                    </div>
                                    <button
                                        class="inline-flex items-center h-8 px-2 rounded-lg bg-white text-stone-900 text-xs font-medium hover:bg-white/90 transition font-nunito">
                                        Open
                                        <svg width="16" height="16" viewBox="0 0 24 24" class="ml-1" fill="none"
                                            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                            stroke-linejoin="round">
                                            <path d="M5 12h14"></path>
                                            <path d="M12 5l7 7-7 7"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Right stack -->
                        <div class="col-span-12 md:col-span-6 space-y-3">
                            <div
                                class="relative h-28 rounded-2xl overflow-hidden border border-white/10 bg-white/[0.02]">
                                <div class="absolute inset-0 flex items-center justify-between px-4">
                                    <div class="flex items-center gap-2">
                                        <span
                                            class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white/5 border border-white/10">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                                stroke-linejoin="round" aria-hidden="true">
                                                <path d="M9 18V5l12-2v13"></path>
                                                <circle cx="6" cy="18" r="3"></circle>
                                                <circle cx="18" cy="16" r="3"></circle>
                                            </svg>
                                        </span>
                                        <div class="">
                                            <p class="text-sm font-medium tracking-tight font-nunito">Branch previews
                                            </p>
                                            <p class="text-xs text-white/60 font-nunito">Auto-link PRs to issues</p>
                                        </div>
                                    </div>
                                    <span class="text-xs text-red-400 font-nunito">Synced</span>
                                </div>
                            </div>

                            <div
                                class="group relative h-48 sm:h-56 rounded-2xl overflow-hidden border border-white/10 bg-stone-900">
                                <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/89eb3a29-9852-4008-8865-22926b2c8cb0_800w.jpg"
                                    alt="Deployment" class="absolute inset-0 w-full h-full object-cover opacity-50"
                                    style="">
                                <div
                                    class="absolute inset-0 bg-gradient-to-t from-stone-950/70 via-stone-950/20 to-transparent">
                                </div>
                                <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between">
                                    <div class="">
                                        <p class="text-xs text-white/60 font-nunito">Release train</p>
                                        <p class="text-lg font-semibold tracking-tight font-nunito">0 incidents this
                                            week</p>
                                    </div>
                                    <span
                                        class="inline-flex items-center h-8 text-xs text-white/80 bg-white/5 border-white/10 border rounded-lg pr-2 pl-2 font-nunito">Rollback</span>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>

                <!-- Quick stats -->
                <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <div
                        class="border-white/10 border rounded-xl pt-2 pr-3 pb-2 pl-3 shadow-[0px_0px_0px_1px_rgba(0,0,0,0.06),0px_1px_1px_-0.5px_rgba(0,0,0,0.06),0px_3px_3px_-1.5px_rgba(0,0,0,0.06),_0px_6px_6px_-3px_rgba(0,0,0,0.06),0px_12px_12px_-6px_rgba(0,0,0,0.06),0px_24px_24px_-12px_rgba(0,0,0,0.06)] backdrop-blur-lg">
                        <p class="text-xs text-white/60 font-nunito">Lead time</p>
                        <p class="text-base font-semibold tracking-tight font-nunito">2.1d</p>
                    </div>
                    <div
                        class="border-white/10 border rounded-xl pt-2 pr-3 pb-2 pl-3 shadow-[0px_0px_0px_1px_rgba(0,0,0,0.06),0px_1px_1px_-0.5px_rgba(0,0,0,0.06),0px_3px_3px_-1.5px_rgba(0,0,0,0.06),_0px_6px_6px_-3px_rgba(0,0,0,0.06),0px_12px_12px_-6px_rgba(0,0,0,0.06),0px_24px_24px_-12px_rgba(0,0,0,0.06)] backdrop-blur-lg">
                        <p class="text-xs text-white/60 font-nunito">On-time delivery</p>
                        <p class="text-base font-semibold tracking-tight font-nunito">96%</p>
                    </div>
                    <div
                        class="border-white/10 border rounded-xl pt-2 pr-3 pb-2 pl-3 shadow-[0px_0px_0px_1px_rgba(0,0,0,0.06),0px_1px_1px_-0.5px_rgba(0,0,0,0.06),0px_3px_3px_-1.5px_rgba(0,0,0,0.06),_0px_6px_6px_-3px_rgba(0,0,0,0.06),0px_12px_12px_-6px_rgba(0,0,0,0.06),0px_24px_24px_-12px_rgba(0,0,0,0.06)] backdrop-blur-lg">
                        <p class="text-xs text-white/60 font-nunito">Cycle time</p>
                        <p class="text-base font-semibold tracking-tight font-nunito">7.4h</p>
                    </div>
                    <div
                        class="border-white/10 border rounded-xl pt-2 pr-3 pb-2 pl-3 shadow-[0px_0px_0px_1px_rgba(0,0,0,0.06),0px_1px_1px_-0.5px_rgba(0,0,0,0.06),0px_3px_3px_-1.5px_rgba(0,0,0,0.06),_0px_6px_6px_-3px_rgba(0,0,0,0.06),0px_12px_12px_-6px_rgba(0,0,0,0.06),0px_24px_24px_-12px_rgba(0,0,0,0.06)] backdrop-blur-lg">
                        <p class="text-xs text-white/60 font-nunito">NPS</p>
                        <p class="text-base font-semibold tracking-tight font-nunito">72</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Cards Section -->
    <section id="cards" class="mt-4 md:mt-8">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            <!-- Card 1 -->
            <article
                class="group relative rounded-3xl overflow-hidden bg-stone-900 h-80 shadow-xl border border-white/10">
                <div
                    class="absolute inset-0 bg-[url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/61b8e1b5-22b1-4280-8ced-ed3ee0678a32_1600w.jpg)] bg-cover">
                </div>
                <div class="absolute bottom-0 left-0 right-0 pt-6 pr-6 pb-6 pl-6">
                    <h3
                        class="text-white text-xl md:text-2xl leading-snug tracking-tight mb-1 font-nunito font-semibold">
                        Purpose-built for product development
                    </h3>
                    <p class="text-white/70 text-sm mb-3 font-nunito">Issues, docs, and sprints in one focused surface.
                    </p>
                    <span
                        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/5 border border-white/15 text-white/90 transition group-hover:bg-white/10">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </span>
                </div>
            </article>

            <!-- Card 2 -->
            <article
                class="group relative rounded-3xl overflow-hidden bg-stone-900 h-80 shadow-xl border border-white/10">
                <div
                    class="absolute inset-0 bg-[url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/78877756-9e45-410e-b630-78c3dfb8e94c_1600w.jpg)] bg-cover">
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3
                        class="text-white text-xl md:text-2xl leading-snug tracking-tight mb-1 font-nunito font-semibold">
                        Designed to move fast</h3>
                    <p class="text-white/70 text-sm mb-3 font-nunito">Keyboard-first, zero-friction navigation and
                        editing.</p>
                    <span
                        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/5 border border-white/15 text-white/90 transition group-hover:bg-white/10">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M5 12h14"></path>
                            <path d="M12 5l7 7-7 7"></path>
                        </svg>
                    </span>
                </div>
            </article>

            <!-- Card 3 -->
            <article
                class="group relative rounded-3xl overflow-hidden bg-stone-900 h-80 shadow-xl border border-white/10">
                <div
                    class="absolute inset-0 bg-[url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/4f29f67f-c043-4d68-9a80-d6f2dc0770fd_800w.jpg)] bg-cover">
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3
                        class="text-white text-xl md:text-2xl leading-snug tracking-tight mb-1 font-nunito font-semibold">
                        Crafted with care</h3>
                    <p class="text-white/70 text-sm mb-3 font-nunito">Polished UI, predictable workflows, fewer
                        surprises.</p>
                    <span
                        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/5 border border-white/15 text-white/90 transition group-hover:bg-white/10">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                            class="">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </span>
                </div>
            </article>
        </div>
    </section>

    <!-- Feature Highlights -->
    <section id="features" class="max-w-7xl mx-auto px-6 mt-16">
        <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="flex items-start gap-3">
                    <span
                        class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 border border-white/10">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                            <path d="M3 9h18M9 21V9"></path>
                        </svg>
                    </span>
                    <div>
                        <h4 class="text-base font-semibold tracking-tight font-nunito">Sprint planning</h4>
                        <p class="text-sm text-white/70 font-nunito">Capacity-aware estimates, drag-and-drop scopes,
                            carryover prevention.</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
